// Vendored from OVO (Merck © 2025, MIT License)
// Adapted for AWS Batch execution.

timeline.overwrite = true
dag.overwrite = true
report.overwrite = true
trace.overwrite = true

params {
    // Required parameters
    input_pdb = null
    tools = null
    chains = null

    // Optional parameters
    batch_size = 50

    // Container registry prefix
    // Local/standard: '' (uses Docker Hub endurestability/)
    // AWS Batch: '799850497656.dkr.ecr.us-west-2.amazonaws.com/' (ECR private)
    docker_repository = ""

    // AWS Batch queue name (set via Seqera compute env or --params)
    cpu_queue = "TowerForge-6ormrO3FWFIJhiQlP55mcl-work"
}

profiles {
    standard {
        docker.enabled = true
    }

    awsbatch {
        process.executor = 'awsbatch'
        aws.region = 'us-west-2'
        docker.enabled = true
        params.docker_repository = '799850497656.dkr.ecr.us-west-2.amazonaws.com/'

        process {
            withLabel: 'cpu' {
                queue = "${params.cpu_queue}"
                cpus = 1
                memory = '1 GB'
            }
            withLabel: 'seq_composition' {
                queue = "${params.cpu_queue}"
                cpus = 2
                memory = '4 GB'
            }
            withLabel: 'dssp' {
                queue = "${params.cpu_queue}"
                cpus = 2
                memory = '4 GB'
            }
            withLabel: 'proteinsol' {
                queue = "${params.cpu_queue}"
                cpus = 1
                memory = '1 GB'
            }
        }
    }
}
