// Vendored from OVO (Merck © 2025, MIT License)
// Adapted for AWS Batch execution.

params {

    // optional parameters
    cyclic = false
    save_traj = false
    num_designs = 1
    run_parameters = ""
    hotspot = ""
    save_traj = false

    // required parameters
    contig = null
    input_pdb = null

    // output directory
    publish_dir = "s3://endure-design-outputs/runs/"

    // ENDURE-PATCH: models on S3 instead of local reference_files_dir
    rfdiffusion_models_path = "s3://endure-design-outputs/reference-models/rfdiffusion/"

    // ENDURE-PATCH: GPU queue for AWS Batch routing
    gpu_queue = null
}

def limit_memory(memory) {
    if (!params.containsKey("max_memory")) {
        return memory;
    }
    if ((memory as nextflow.util.MemoryUnit) > (params.max_memory as nextflow.util.MemoryUnit)) {
        return params.max_memory
    }
    return memory
}

process {
    withLabel: gpu {
        memory = limit_memory("16 GB")
        // ENDURE-PATCH: route GPU tasks to correct Forge queue
        queue = params.gpu_queue
    }
}

profiles {
    // ENDURE-PATCH: added awsbatch profile for Seqera + AWS Batch execution
    awsbatch {
        process.executor = 'awsbatch'
        params.docker_repository = '799850497656.dkr.ecr.us-west-2.amazonaws.com/'
    }
}
