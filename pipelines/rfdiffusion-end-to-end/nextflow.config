// Vendored from OVO (Merck (c) 2025, MIT License) with ENDURE-PATCH modifications

params {
    // optional parameters
    max_memory = null
    batch_size = 50
    backbone_generator = "rfdiffusion"
    save_traj = false
    hotspot = ""
    custom_backbones = null
    rfdiffusion_num_designs = 1
    rfdiffusion_run_parameters = ""
    rfdiffusion3_spec_overrides = ""
    backbone_filters = "none"
    mpnn_fastrelax_cycles = 0
    mpnn_num_sequences = 1
    mpnn_run_parameters = ""
    disable_pyrosetta_scoring = true  // ENDURE-PATCH: default true since pyrosetta not vendored
    esmfold_fp16 = false
    refolding_tests = null
    refolding_chains = "A"

    // Model paths — default to S3
    rfdiffusion_models_path = "s3://endure-design-outputs/reference-models/rfdiffusion/"
    alphafold_models_path = "s3://endure-design-outputs/reference-models/alphafold/alphafold_params_2022-12-06.tar"
    esmfold_models_path = "s3://endure-design-outputs/reference-models/esmfold_v1/"
    boltz_models_path = "s3://endure-design-outputs/reference-models/boltz/"

    // Publish directory
    publish_dir = "s3://endure-design-outputs/runs/"

    // required parameters
    design_type = null
    rfdiffusion_contig = null
    rfdiffusion_input_pdb = null

    // ENDURE-PATCH: ECR repository prefix and queue names (overridden by awsbatch profile)
    docker_repository = ""
    gpu_queue = null
    cpu_queue = null
}


def limit_memory(memory) {
    if (!params.containsKey("max_memory") || !params.max_memory) {
        return memory;
    }
    if ((memory as nextflow.util.MemoryUnit) > (params.max_memory as nextflow.util.MemoryUnit)) {
        return params.max_memory
    }
    return memory
}


// ENDURE-PATCH: label-based memory limits
process {
    withLabel: gpu {
        queue = params.gpu_queue
        memory = limit_memory("16 GB")
    }
    withLabel: cpu {
        queue = params.cpu_queue
        memory = limit_memory("4 GB")
    }
    // OVO-original per-label overrides
    withLabel: rfdiffusion {
        memory = limit_memory("16 GB")
    }
    withLabel: colabdesign {
        memory = limit_memory("32 GB")
    }
}


// ENDURE-PATCH: AWS Batch profile
profiles {
    awsbatch {
        process.executor = 'awsbatch'
        aws.region = 'us-west-2'
        params.docker_repository = '799850497656.dkr.ecr.us-west-2.amazonaws.com/'
    }

    local {
        process.executor = 'local'
        docker.enabled = true
    }
}
